{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-arm64",
      "displayName": "Visual Studio 2026 ARM64 (ClangCL)",
      "generator": "Visual Studio 18 2026",
      "architecture": "ARM64",
      "toolset": "ClangCL",
      "binaryDir": "${sourceDir}/build_vs",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-arm64-debug",
      "configurePreset": "vs2026-arm64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-arm64-release",
      "configurePreset": "vs2026-arm64",
      "configuration": "Release"
    }
  ]
}
